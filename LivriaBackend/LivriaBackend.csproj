        <AutoGen>True</AutoGen>
        <DependentUpon>DataAnnotations.resx</DependentUpon>
      </Compile>
      <Compile Update="commerce\Application\Resources\DataAnnotations.Designer.cs">
        <DesignTime>True</DesignTime>
        <AutoGen>True</AutoGen>
        <DependentUpon>DataAnnotations.resx</DependentUpon>
      </Compile>
      <Compile Update="commerce\Application\Resources\DataAnnotations.Designer.cs">
        <DesignTime>True</DesignTime>
        <AutoGen>True</AutoGen>
        <DependentUpon>DataAnnotations.resx</DependentUpon>
      </Compile>
    </ItemGroup>

</Project>
